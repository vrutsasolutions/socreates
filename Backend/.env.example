# ── Cloudflare ───────────────────────────────

cloudflare.r2.account-id=
cloudflare.r2.access-key=
cloudflare.r2.secret-key=


# ── Razorpay (memberships — UNCHANGED) ─────────────
# Test-mode keys from the Razorpay dashboard (Settings → API Keys, Test Mode).
# Set RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET in your shell, IDE run config, or
# Backend/.env. Blank by default so the app still boots; /api/payment/create-order
# returns a clear "not configured" error until real keys are supplied.
razorpay.key-id=${RAZORPAY_KEY_ID:}
razorpay.key-secret=${RAZORPAY_KEY_SECRET:}


# ── Cashfree Payouts (creator payouts) ──────────
# Get these from the Cashfree Merchant Dashboard →
# Payouts → Developers → API Keys.
#
# Keep CASHFREE_PAYOUT_ENV=sandbox until Cashfree KYC is approved AND the
# full sandbox test suite is green (see BATCH 3 test plan).
# Only then flip to production and swap CLIENT_ID / CLIENT_SECRET / WEBHOOK_SECRET
# to the live-mode values.
CASHFREE_PAYOUT_ENV=sandbox
CASHFREE_PAYOUT_CLIENT_ID=
CASHFREE_PAYOUT_CLIENT_SECRET=
CASHFREE_PAYOUT_WEBHOOK_SECRET=
CASHFREE_PAYOUT_API_VERSION=2024-01-01


# ── RazorpayX (DEPRECATED — superseded by Cashfree above) ──────
# Kept commented for rollback. Delete after 30-day migration window closes.
# RAZORPAYX_ACCOUNT_NUMBER=
# RAZORPAYX_WEBHOOK_SECRET=


# ── Groq AI ────────────────────────────────────────
groq.api.key=


# ── Gmail SMTP ───────────────────────────────

spring.mail.username=
spring.mail.password=



# ── Google Client ID ───────────────────────────────

google.client.id=

# ── PAN Encryption Key ────────────────────────────────
pan_encryption_key=
