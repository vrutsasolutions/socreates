# Copy to `.env` and fill in. All vars must be prefixed VITE_ to reach the app.

# Google Sign-In — OAuth Web client ID from Google Cloud Console
# (APIs & Services → Credentials). Required only once USE_MOCK.googleAuth=false.
# Authorized JavaScript origin for local dev: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Realtime notifications WebSocket (defaults to http://localhost:8081/ws)
VITE_WS_URL=

# Razorpay key id for the Membership checkout
VITE_RAZORPAY_KEY_ID=


# Gates the "Run monthly distribution" button on the Creator Dashboard so it
# only renders for this account. Purely cosmetic — the backend's ROLE_ADMIN
# check (app.admin.email) is what actually enforces this. Should match that
# same email. Defaults to vrutsasolutions@gmail.com if unset.
VITE_ADMIN_EMAIL=
